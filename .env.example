# ══════════════════════════════════════════════════
# WASITI 2027 — .env.example
# انسخ هذا الملف إلى .env واملأ القيم
# ══════════════════════════════════════════════════

# ── قاعدة البيانات ──
POSTGRES_DB=wasity
POSTGRES_USER=wasity
POSTGRES_PASSWORD=your_password_here
DATABASE_URL=postgres://wasity:your_password_here@postgres:5432/wasity

# ─ـ Redis ─ـ
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

# ─ـ JWT ─ـ
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# ─ـ منافذ الخدمات ─ـ
AUTH_SERVICE_PORT=3005
LISTINGS_SERVICE_PORT=3004
AI_SERVICE_PORT=8000
API_GATEWAY_PORT=8080
FRONTEND_PORT=3000

# ─ـ MinIO ─ـ
MINIO_ROOT_USER=wasity_admin
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=wasity-images
MINIO_PUBLIC_URL=http://localhost:9000

# ─ـ Frontend ─ـ
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_CDN_URL=http://localhost:9000

# ─ـ CORS ─ـ
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─ـ AI ─ـ
AI_MODEL_PATH=/app/models
AI_BATCH_SIZE=100
