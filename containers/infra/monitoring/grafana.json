{
  "title": "WASITI 2027 Monitoring Dashboard",
  "uid": "wasiti-main-dashboard",
  "version": 1,
  "editable": true,
  "tags": ["wasiti", "monitoring", "production"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "📊 إحصائيات النظام العامة",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "up{job='api-gateway'}",
          "legendFormat": "API Gateway",
          "refId": "A"
        },
        {
          "expr": "up{job='frontend'}",
          "legendFormat": "Frontend",
          "refId": "B"
        },
        {
          "expr": "up{job='postgres'}",
          "legendFormat": "PostgreSQL",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "title": "🐳 حالة حاويات Docker",
      "type": "table",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "container_last_seen{container_label_com_docker_compose_service!=''}",
          "format": "table",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "⚡ زمن استجابة الخدمات (ms)",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, service))",
          "legendFormat": "P95 {{service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "📦 عدد طلبات API",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 0, "y": 14},
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "طلبات/ثانية",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "👤 مستخدمين نشطين",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 4, "y": 14},
      "targets": [
        {
          "expr": "sum(active_users_total)",
          "legendFormat": "مستخدمين",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "📝 إعلانات نشطة",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 8, "y": 14},
      "targets": [
        {
          "expr": "sum(active_listings_total)",
          "legendFormat": "إعلانات",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "💾 قاعدة البيانات - اتصالات نشطة",
      "type": "graph",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "pg_stat_database_numbackends",
          "legendFormat": "اتصالات نشطة",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "💽 استخدام القرص (PostgreSQL)",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 28},
      "targets": [
        {
          "expr": "pg_database_size_bytes / (1024^3)",
          "legendFormat": "GB",
          "refId": "A"
        }
      ],
      "unit": "decgbytes",
      "min": 0
    },
    {
      "id": 9,
      "title": "🧠 الذاكرة المستخدمة (Redis)",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 28},
      "targets": [
        {
          "expr": "redis_memory_used_bytes / (1024^2)",
          "legendFormat": "MB",
          "refId": "A"
        }
      ],
      "unit": "decbytes"
    },
    {
      "id": 10,
      "title": "🔒 محاولات تسجيل الدخول الفاشلة",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 0, "y": 34},
      "targets": [
        {
          "expr": "sum(failed_login_attempts_total)",
          "legendFormat": "محاولات فاشلة",
          "refId": "A"
        }
      ],
      "unit": "short"
    },
    {
      "id": 11,
      "title": "✅ عمليات المصادقة الناجحة",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 4, "y": 34},
      "targets": [
        {
          "expr": "sum(successful_logins_total)",
          "legendFormat": "تسجيلات دخول",
          "refId": "A"
        }
      ]
    },
    {
      "id": 12,
      "title": "💰 إيرادات هذا الشهر",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 8, "y": 34},
      "targets": [
        {
          "expr": "sum(revenue_monthly_total)",
          "legendFormat": "إيرادات",
          "refId": "A"
        }
      ],
      "unit": "currencyUSD"
    },
    {
      "id": 13,
      "title": "📊 إحصائيات حاويات Docker",
      "type": "table",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40},
      "targets": [
        {
          "expr": "container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=''}",
          "format": "table",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        },
        {
          "expr": "container_memory_usage_bytes{container_label_com_docker_compose_service!=''}",
          "format": "table",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "B"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 27,
  "style": "dark",
  "time": {
    "from": "now-6h",
    "to": "now"
  }
}