# ══════════════════════════════════════════════════
# WASITI 2027 — User Service Dockerfile
# ══════════════════════════════════════════════════

FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* ./
RUN npm ci --only=production
COPY . .
RUN npm run build

EXPOSE 3000

CMD ["node", "dist/main.js"]